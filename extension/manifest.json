{
  "manifest_version": 3,
  "name": "lc-notes",
  "version": "0.1.0",
  "key": "",
  "description": "Log and review LeetCode problems into lc-tracker without leaving the problem page.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "lc-notes"
  },
  "permissions": ["storage", "identity"],
  "host_permissions": [
    "https://nwvltwgpkottizjkkiei.supabase.co/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "css": ["src/panel.css"],
      "js": [
        "config.local.js",
        "vendor/supabase.js",
        "src/dates.js",
        "src/sm2.js",
        "src/patterns.js",
        "src/session.js",
        "src/supabaseClient.js",
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
